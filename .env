# ── App ─────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_AUTH_URL=http://localhost:5001/api/auth

# ── Auth Server ──────────────────────────────────────
AUTH_PORT=5001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Database ─────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=auth_db

# ── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_super_secret_2024
JWT_REFRESH_SECRET=change_me_refresh_super_secret_2024
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cookie (for SSO across subdomains set e.g. .example.com) ─
# COOKIE_DOMAIN=.example.com
NODE_ENV=development